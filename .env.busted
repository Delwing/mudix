# Loaded by `vite --mode busted` (npm run dev:busted). Turns on the
# VITE_BUSTED-gated import.meta.glob in LuaRuntime.ts so the vendored busted
# runtime + Mudlet spec corpus are bundled and window.__runBusted is exposed.
# Kept out of the default .env so production / normal dev builds never bundle it.
VITE_BUSTED=1
